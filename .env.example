# Copy this file to .env.local and fill secrets locally.

# SQLite database. Relative paths are resolved from the project root.
DATABASE_URL=sqlite:///./data/flatfeed.db

# Listing parsing is fully deterministic and local: no LLM, no token, zero cost.
# The OpenAI credentials below are used only by the optional AI QA layer
# (AI_QA_PROVIDER=openai). AI QA is admin-only and never required for matching.
OPENAI_API_KEY=
OPENAI_INPUT_PRICE_PER_1M=0.75
OPENAI_OUTPUT_PRICE_PER_1M=4.50

# Telegram bot.
# Create the token via @BotFather and paste it here.
TELEGRAM_BOT_TOKEN=
BOT_SCAN_INTERVAL_SECONDS=3600
BOT_SCAN_MIN_SECONDS=2700
BOT_SCAN_MAX_SECONDS=3600
BOT_BACKGROUND_ENABLED=false
BOT_NOTIFICATION_LIMIT_PER_USER=10
MANUAL_REFRESH_TIMEOUT_SECONDS=120

# Optional URL of the Streamlit AI QA effectiveness dashboard.
# For local admin demos, the bot can start Streamlit and send this localhost URL.
DASHBOARD_URL=
DASHBOARD_PORT=8502
DASHBOARD_AUTOSTART=true

# Admin monitoring alerts.
# Comma-separated Telegram user IDs. Example: 123456789,987654321
ADMIN_TELEGRAM_USER_IDS=
SOURCE_FAILURE_ALERT_THRESHOLD=3
SOURCE_ALERT_COOLDOWN_SECONDS=3600

# Synthetic catalog controls.
SYNTHETIC_SEED=20260623
SYNTHETIC_LISTING_COUNT=15

# AI QA validation for parser quality.
# mock is local and free; openai is optional and admin-only.
AI_QA_ENABLED=false
AI_QA_PROVIDER=mock
AI_QA_MODEL=gpt-5.4-mini
AI_QA_ALERT_RISK_THRESHOLD=75
AI_QA_DAILY_MAX_COST_USD=0.25
AI_QA_MAX_LISTING_CHARS=6000
AI_QA_BACKFILL_BATCH_SIZE=10
AI_QA_CONCURRENCY=3
